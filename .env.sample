# Copy this file to the env file required by your target script, for example:
# .env.development, .env.beta, .env.mainnet-fork, or .env.
#
# Do not commit real API keys, project IDs, RPC keys, Sentry DSNs, or
# environment-specific contract addresses.

ETHEREUM_NETWORK=
PUBLIC_BASE_PATH=/
PUBLIC_BASE_PATH_SECTIONS=/
CHECK_NODE_SYNC=false
NODE_ENV=development
IS_DEV=true
VERSION=
TARGET_NETWORKS=1,137

# Analytics and monitoring
GA_TRACKER_ID=
SENTRY_URL=

# Ethereum mainnet
NETWORK_1_STATUS_URL=
NETWORK_1_REGISTRY=
NETWORK_1_ERC20=

# Polygon mainnet
NETWORK_137_STATUS_URL=
NETWORK_137_REGISTRY=
NETWORK_137_ERC20=

# Legacy/staging networks, only if still used by the selected env file
NETWORK_3_STATUS_URL=
NETWORK_3_REGISTRY=
NETWORK_3_ERC20=

# Provider and wallet infrastructure
INFURA_ID=
REOWN_PROJECT_ID=
WALLETCONNECT_PROJECT_ID=
